    alternate-background-color: #333;
	padding:0px;
}

/* ---------- Header ---------- */
QHeaderView::section {
    background-color: #3a3a3a;
    color: #ffffff;
    font-weight: bold;
    border: 1px solid #555;
}

QTableView::item {
    padding: 0px;
}

