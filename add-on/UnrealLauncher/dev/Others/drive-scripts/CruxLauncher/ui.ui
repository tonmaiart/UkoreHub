                  <string notr="true">/* ---------- Base table ---------- */
QTableView {
    background-color: #2b2b2b;
    color: #f0f0f0;
    border: 2px solid #444;
    gridline-color: #555;
    outline: none;
    alternate-background-color: #333;
}

/* ---------- Header ---------- */
QHeaderView::section {
    background-color: #3a3a3a;
    color: #ffffff;
    font-weight: bold;
    border: 1px solid #555;
    padding: 6px 10px;
}


/* ---------- Selected (Active) ---------- */
