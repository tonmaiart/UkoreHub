.venv/
__pycache__/
*.pyc
# data/projects.json, data/system_config.json, and data/thumbnails/ are
# intentionally NOT ignored — they're shared studio-wide (registry, settings,
# repo thumbnail images), tracked in this repo so everyone gets them via
# git pull / Update and Restart.
data/local_config.json
data/github_token.json
# Per-plugin settings mirror the same split: data/plugins/studio/*.json is
# shared (written by studio-authored plugins), data/plugins/local/*.json is
# per-machine/experimental — see core/plugin_config_store.py.
data/plugins/local/
.pytest_cache/
# plugins/studio is git-tracked and distributed like data/programs.json;
# plugins/local is per-machine/experimental — see core/plugin_loader.py.
plugins/local/
# Forced workspace_root (see launcher.py) — actual cloned target repos live
# here, per-machine and potentially huge; never tracked.
/projects/
# PyInstaller intermediates from packaging/build_exe.py — regenerate every
# build, never committed. The resulting UkoreHub.exe at the repo root IS
# committed — a shared studio-wide binary, same pattern as
# data/thumbnails/ and data/programs.json above.
/build/
*.spec
